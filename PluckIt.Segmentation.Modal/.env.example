# Shared bearer token checked by the Modal segmentation endpoint.
SEGMENTATION_SHARED_TOKEN=replace-with-long-random-secret

# BiRefNet model selection.
BIREFNET_MODEL_ID=ZhengPeng7/BiRefNet

# Request/processing controls.
MAX_IMAGE_MB=10
MASK_THRESHOLD=0.5
SCALEDOWN_WINDOW_SECONDS=120

# Persistent model cache Volume settings.
MODEL_CACHE_VOLUME_NAME=pluckit-birefnet-cache
MODEL_CACHE_DIR=/cache

# Modal Secret resource name that stores SEGMENTATION_SHARED_TOKEN.
SEGMENTATION_SECRET_NAME=pluckit-segmentation
