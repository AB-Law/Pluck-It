# Test environment variables — safe stubs used by all Python unit tests.
# Real Azure services are NEVER called during unit tests; all Cosmos/OpenAI
# calls are patched with mocks in conftest.py.
AZURE_OPENAI_ENDPOINT=https://test.openai.azure.com/
AZURE_OPENAI_API_KEY=test-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
COSMOS_DB_ENDPOINT=https://localhost:8081
COSMOS_DB_KEY=test-key
COSMOS_DB_DATABASE=PluckIt
COSMOS_DB_CONTAINER=Wardrobe
COSMOS_DB_USER_PROFILES_CONTAINER=UserProfiles
COSMOS_DB_CONVERSATIONS_CONTAINER=Conversations
COSMOS_DB_DIGESTS_CONTAINER=Digests
BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=test;AccountKey=test==;EndpointSuffix=core.windows.net
UPLOADS_CONTAINER_NAME=uploads
ARCHIVE_CONTAINER_NAME=archive
LOCAL_DEV_USER_ID=test-user-001
CORS_ALLOWED_ORIGINS=http://localhost:4200
OPEN_METEO_BASE_URL=https://api.open-meteo.com
