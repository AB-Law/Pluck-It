{
  "/api": {
    "target": "http://localhost:7072",
    "secure": false,
    "changeOrigin": true,
    "logLevel": "info",
    "proxyTimeout": 120000,
    "timeout": 120000
  },
  "/reddit-api": {
    "target": "https://www.reddit.com",
    "secure": true,
    "changeOrigin": true,
    "pathRewrite": {
      "^/reddit-api": ""
    },
    "logLevel": "info"
  },
  "/scraper": {
    "target": "http://localhost:7071",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": {
      "^/scraper": "/api/scraper"
    },
    "logLevel": "info"
  },
  "/taste": {
    "target": "http://localhost:7071",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": {
      "^/taste": "/api/taste"
    },
    "logLevel": "info"
  }
}