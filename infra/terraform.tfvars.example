# Example Terraform variables - copy to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to version control - it contains secrets

subscription_id    = "your-subscription-id"
location           = "westeurope"  # or your preferred region
project_name       = "pluckit"
environment        = "prod"

# Azure OpenAI configuration
ai_gpt4o_endpoint    = "https://your-ai-resource.openai.azure.com/"
ai_api_key           = "your-api-key-here"

# CORS allowed origins - add your frontend domain(s) here
cors_allowed_origins = [
  "https://happy-ocean-0c606bd00.4.azurestaticapps.net",  # Production Static Web App (default SWA hostname)
  "https://pluckit.omakashay.com",                        # Custom domain
  "http://localhost:4200"                                  # Local development (optional)
]

# Static Web App repo linkage (required for Google OAuth via staticwebapp.config.json)
swa_repository_url    = "https://github.com/AB-Law/Pluck-It"
swa_repository_branch = "main"
swa_repository_token  = "ghp_your_github_pat_with_repo_scope"

# Google OAuth 2.0 Client ID — used by GIS (frontend) and GoogleTokenValidator (API).
# Create at console.cloud.google.com → APIs & Services → Credentials.
google_oauth_client_id = "YOUR_CLIENT_ID.apps.googleusercontent.com"
# Client secret is no longer used; the variable is kept for backwards compatibility.
# google_oauth_client_secret = ""
